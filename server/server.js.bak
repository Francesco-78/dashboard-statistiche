// Fallback: ultimo valore non-null per paese
function lastNonNullValue(arr) {
  for (let i = arr.length - 1; i >= 0; i--) {
    if (arr[i] !== null && arr[i] !== undefined) return { value: arr[i], index: i };
  }
  return null;
}

